# Template for Streamlit secrets. Copy to `.streamlit/secrets.toml` for local
# runs, or paste these keys into the Streamlit Community Cloud dashboard
# (App → Settings → Secrets). The real secrets.toml is gitignored — never
# commit real keys.

APIFY_TOKEN = "your_apify_token_here"
ANTHROPIC_API_KEY = "your_anthropic_key_here"

# Used by the NZ Outreach Researcher (outreach_researcher.py). Starts with pplx-.
PERPLEXITY_API_KEY = "your_perplexity_key_here"

# Optional: durable research-history storage for the Outreach Researcher.
# Without these, history is local-only and is wiped on Streamlit Cloud
# reboot/redeploy. With them, history syncs to a private Supabase Storage bucket
# and survives. Create a free Supabase project, add a (private) Storage bucket,
# and use the service_role key here. SUPABASE_BUCKET defaults to outreach-history.
SUPABASE_URL = "https://your-project.supabase.co"
SUPABASE_KEY = "your_supabase_service_role_key"
SUPABASE_BUCKET = "outreach-history"
