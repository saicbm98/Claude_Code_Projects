        <mxCell id="ee15" edge="1" source="e_r7" target="e_normal" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ee16" edge="1" source="e_high" target="e_capture" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ee17" edge="1" source="e_normal" target="e_capture" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ee18" edge="1" source="e_capture" target="e_summary" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ee19" edge="1" source="e_summary" target="e_slack" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ee20" edge="1" source="e_summary" target="e_email" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ee21" edge="1" source="e_slack" target="e_user_msg" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ee22" edge="1" source="e_email" target="e_user_msg" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ee23" edge="1" source="e_user_msg" target="e_end" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>

  <!-- ═══════════════════════════════════════════════════════ -->
  <!-- PAGE 6: COMPLIANCE & DISCLAIMER LOGIC                  -->
  <!-- ═══════════════════════════════════════════════════════ -->
  <diagram id="d_compliance" name="6. Compliance Logic">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="cp_start" value="Any response being generated" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="380" y="30" width="280" height="60" as="geometry" />
        </mxCell>

        <mxCell id="cp_q1" value="Does response mention&#xa;yield, returns, or investing?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="350" y="150" width="300" height="100" as="geometry" />
        </mxCell>

        <mxCell id="cp_d1" value="Append disclaimer:&#xa;&quot;Your capital is at risk.&#xa;Consult a qualified financial advisor.&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#e65100;" vertex="1" parent="1">
          <mxGeometry x="740" y="165" width="280" height="70" as="geometry" />
        </mxCell>

        <mxCell id="cp_q2" value="Does response mention&#xa;regulation or FCA status?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="350" y="330" width="300" height="100" as="geometry" />
        </mxCell>

        <mxCell id="cp_d2" value="Include:&#xa;Round Financial Ltd FRN 995009&#xa;Appointed rep of Wealthkernel FRN 723719&#xa;ISO 27001:2022 certified" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#e65100;" vertex="1" parent="1">
          <mxGeometry x="740" y="345" width="280" height="80" as="geometry" />
        </mxCell>

        <mxCell id="cp_q3" value="Does response mention&#xa;data or bank credentials?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="350" y="510" width="300" height="100" as="geometry" />
        </mxCell>

        <mxCell id="cp_d3" value="Include:&#xa;Credentials never stored&#xa;Open Banking compliant · 2FA required&#xa;No data sold to third parties" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#e65100;" vertex="1" parent="1">
          <mxGeometry x="740" y="525" width="280" height="80" as="geometry" />
        </mxCell>

        <mxCell id="cp_out" value="Response sent to user" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="390" y="700" width="260" height="60" as="geometry" />
        </mxCell>

        <!-- Edges -->
        <mxCell id="cpe1" edge="1" source="cp_start" target="cp_q1" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="cpe2" value="Yes" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="cp_q1" target="cp_d1" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="cpe3" value="No" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="cp_q1" target="cp_q2" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="cpe4" edge="1" source="cp_d1" target="cp_q2" parent="1">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="880" y="280" /><mxPoint x="880" y="310" /><mxPoint x="500" y="310" /></Array></mxGeometry>
        </mxCell>
        <mxCell id="cpe5" value="Yes" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="cp_q2" target="cp_d2" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="cpe6" value="No" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="cp_q2" target="cp_q3" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="cpe7" edge="1" source="cp_d2" target="cp_q3" parent="1">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="880" y="470" /><mxPoint x="880" y="490" /><mxPoint x="500" y="490" /></Array></mxGeometry>
        </mxCell>
        <mxCell id="cpe8" value="Yes" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="cp_q3" target="cp_d3" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="cpe9" value="No" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="cp_q3" target="cp_out" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="cpe10" edge="1" source="cp_d3" target="cp_out" parent="1">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="880" y="650" /><mxPoint x="880" y="670" /><mxPoint x="520" y="670" /></Array></mxGeometry>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>

  <!-- ═══════════════════════════════════════════════════════ -->
  <!-- PAGE 7: SESSION STATE MACHINE                          -->
  <!-- ═══════════════════════════════════════════════════════ -->
  <diagram id="d_state" name="7. Session State Machine">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- States -->
        <mxCell id="s_init" value="" style="ellipse;aspect=fixed;whiteSpace=wrap;html=1;fillColor=#000000;strokeColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="550" y="20" width="40" height="40" as="geometry" />
        </mxCell>

        <mxCell id="s_greeting" value="Greeting" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="480" y="110" width="200" height="60" as="geometry" />
        </mxCell>

        <mxCell id="s_sega" value="Segment A&#xa;Prospect" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="100" y="260" width="180" height="60" as="geometry" />
        </mxCell>

        <mxCell id="s_segb" value="Segment B&#xa;Active Client" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="490" y="260" width="180" height="60" as="geometry" />
        </mxCell>

        <mxCell id="s_segc" value="Segment C&#xa;Established Client" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="880" y="260" width="180" height="60" as="geometry" />
        </mxCell>

        <mxCell id="s_resolved" value="Resolved" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="490" y="420" width="180" height="60" as="geometry" />
        </mxCell>

        <mxCell id="s_followup" value="Follow-Up" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="850" y="420" width="180" height="60" as="geometry" />
        </mxCell>

        <mxCell id="s_escalated" value="Escalated" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="140" y="420" width="180" height="60" as="geometry" />
        </mxCell>

        <mxCell id="s_handoff" value="Human Handoff" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="140" y="570" width="180" height="60" as="geometry" />
        </mxCell>

        <mxCell id="s_csat" value="CSAT Survey" style="ellipse;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="480" y="700" width="200" height="60" as="geometry" />
        </mxCell>

        <mxCell id="s_end" value="" style="ellipse;aspect=fixed;whiteSpace=wrap;html=1;fillColor=#000000;strokeColor=#000000;" vertex="1" parent="1">
          <mxCell id="s_end_inner" value="" style="ellipse;aspect=fixed;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;" vertex="1" parent="1">
            <mxGeometry x="5" y="5" width="20" height="20" as="geometry" />
          </mxCell>
          <mxGeometry x="545" y="810" width="70" height="70" as="geometry" />
        </mxCell>

        <!-- Transitions -->
        <mxCell id="se1" edge="1" source="s_init" target="s_greeting" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="se2" value="Selects Prospect" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="s_greeting" target="s_sega" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="se3" value="Selects Active Client" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="s_greeting" target="s_segb" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="se4" value="Selects Established Client" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="s_greeting" target="s_segc" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="se5" value="Query answered" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="s_sega" target="s_resolved" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="se6" value="Query answered" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="s_segb" target="s_resolved" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="se7" value="Query answered" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="s_segc" target="s_resolved" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="se8" value="Cannot resolve /&#xa;complaint / KYB overdue" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="s_sega" target="s_escalated" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="se9" value="Cannot resolve" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="s_segb" target="s_escalated" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="se10" value="Cannot resolve" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="s_segc" target="s_escalated" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="se11" value="Another question" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="s_resolved" target="s_followup" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="se12" value="Re-enters segment" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="s_followup" target="s_segb" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="se13" value="Types 'main menu'" style="edgeStyle=orthogonalEdgeStyle;curved=1;" edge="1" source="s_followup" target="s_greeting" parent="1">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="940" y="370" /><mxPoint x="940" y="140" /></Array></mxGeometry>
        </mxCell>

        <mxCell id="se14" value="User is done" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="s_resolved" target="s_csat" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="se15" value="Rep notified via Slack + email" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="s_escalated" target="s_handoff" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="se16" value="Session complete" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="s_handoff" target="s_csat" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="se17" edge="1" source="s_csat" target="s_end" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>

